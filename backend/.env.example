FLASK_ENV=development
FLASK_DEBUG=1

# Security
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too
# Duración del access token JWT (minutos). Si no se setea, default = 60.
JWT_ACCESS_TOKEN_MINUTES=60

# Zona horaria de la aplicación (IANA). Default: America/Argentina/Buenos_Aires.
# Afecta la lógica de "hoy" (facturación, vencimientos) y la serialización ISO al frontend.
APP_TIMEZONE=America/Argentina/Buenos_Aires

# Database (MySQL). Crear la base "sistemaconnect" antes de correr migraciones.
# Ejemplo: mysql -u root -p -e "CREATE DATABASE IF NOT EXISTS sistemaconnect;"
DATABASE_URL=mysql+pymysql://root:root@127.0.0.1:3306/sistemaconnect

# AFIP (WSFE)
AFIP_ENV=HOMOLOGACION  # or PRODUCCION
AFIP_CUIT=20123456789
AFIP_CERT_PATH=./secrets/afip/cert.crt
AFIP_KEY_PATH=./secrets/afip/private.key

# Mikrotik (RouterOS API)
MIKROTIK_HOST=10.0.0.1
MIKROTIK_PORT=8728
MIKROTIK_USER=apiuser
MIKROTIK_PASS=apipass
