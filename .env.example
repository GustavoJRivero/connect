# ============================================================
# Docker Compose - Variables de entorno
# Copiar este archivo como .env y ajustar los valores.
#   cp .env.example .env
# ============================================================

# --- MySQL ---
MYSQL_ROOT_PASSWORD=root
MYSQL_USER=root

# --- Backend (Flask) ---
FLASK_ENV=production
SECRET_KEY=genera-una-clave-segura-aqui
JWT_SECRET_KEY=genera-otra-clave-segura-aqui

# --- AFIP (opcional, dejar vacío si no se usa) ---
AFIP_ENV=HOMOLOGACION
AFIP_CUIT=
AFIP_CERT_PATH=
AFIP_KEY_PATH=

# --- Mikrotik (opcional, dejar vacío si no se usa) ---
MIKROTIK_HOST=
MIKROTIK_PORT=8728
MIKROTIK_USER=
MIKROTIK_PASS=

# --- Frontend ---
# URL pública donde el navegador accede al backend.
# Si se despliega con dominio propio, cambiar por la URL correspondiente.
REACT_APP_API_BASE_URL=http://localhost:5001
