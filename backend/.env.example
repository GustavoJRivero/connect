FLASK_ENV=development
FLASK_DEBUG=1

# Security
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too

# Database (MySQL)
# Example: mysql+pymysql://user:password@127.0.0.1:3306/sistemaconnect
DATABASE_URL=mysql+pymysql://root:root@127.0.0.1:3306/sistemaconnect

# AFIP (WSFE)
AFIP_ENV=HOMOLOGACION  # or PRODUCCION
AFIP_CUIT=20123456789
AFIP_CERT_PATH=./secrets/afip/cert.crt
AFIP_KEY_PATH=./secrets/afip/private.key

# Mikrotik (RouterOS API)
MIKROTIK_HOST=10.0.0.1
MIKROTIK_PORT=8728
MIKROTIK_USER=apiuser
MIKROTIK_PASS=apipass
